# Secrets — API keys live here, never commit
.env

# Environments (rebuild via `python -m venv venv` + pip / renv::restore())
venv/
renv/library/
renv/staging/
renv/sandbox/
.Rproj.user/

# Python bytecode
__pycache__/
*.pyc

# Pipeline data & artifacts — all regenerated by the R collectors and
# scripts/01-02; bet_log.csv / odds_close_*.csv are the exceptions worth
# backing up separately if you care about the historical record.
data/
models/
outputs/
logs/

# Local Claude Code settings
.claude/settings.local.json
.Rhistory
