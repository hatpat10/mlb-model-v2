# Secrets — API keys live here, never commit
.env

# Environments (rebuild via `python -m venv venv` + pip / renv::restore())
venv/
renv/library/
renv/staging/
renv/sandbox/
.Rproj.user/

# Python bytecode
__pycache__/
*.pyc

# Pipeline data & artifacts — regenerated by the R collectors and
# scripts/01-02, EXCEPT the betting history (bet log, bankroll state,
# captured closing lines), which is irreplaceable and therefore tracked.
# Note the `dir/*` + `!` pattern: git cannot re-include a file whose
# parent directory is excluded with `dir/`.
data/*
!data/raw
data/raw/*
!data/raw/odds_close_*.csv
models/*
!models/bankroll_state.json
outputs/*
!outputs/bet_log.csv
logs/

# Local Claude Code settings
.claude/settings.local.json
.Rhistory
